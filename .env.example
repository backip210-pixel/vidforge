# --- Core ---
APP_DATA_DIR=/data
APP_PORT=8080
# APP_HOST=0.0.0.0

# --- Maintenance ---
# Idle temp folders older than this many hours are purged.
# TEMP_MAX_AGE_HOURS=12

# --- Optional basic auth (leave unset for LAN-only use) ---
# APP_USERNAME=admin
# APP_PASSWORD=change-me

# --- Optional CORS (comma-separated origins) ---
# APP_CORS_ORIGINS=https://example.com,https://app.example.com
